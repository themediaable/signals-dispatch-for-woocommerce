{
  "name": "tmasd/signals-dispatch-for-woocommerce",
  "description": "Signals Dispatch for WooCommerce - WhatsApp Cloud API integration",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "TMASD\\Signals\\Dispatch\\": "src/"
    }
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "lint": "@phpcs",
    "lint:fix": "@phpcbf",
    "build:zip": "bash bin/build-zip.sh",
    "release:init": "bash bin/wporg-svn-init.sh",
    "release": "bash bin/wporg-release.sh"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
